{
    "name": "deepa-vscode",
    "displayName": "Deepa Agent",
    "description": "Visual Studio Code extension for Deepa CLI",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "deepa.startChat",
                "title": "Deepa: Start Chat"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "deepa-sidebar",
                    "title": "Deepa Agent",
                    "icon": "$(hubot)"
                }
            ]
        },
        "views": {
            "deepa-sidebar": [
                {
                    "type": "webview",
                    "id": "deepa.chatView",
                    "name": "Chat"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node && esbuild ./src/webview/index.tsx --bundle --outfile=dist/webview.js --format=iife --platform=browser",
        "build": "npm run package"
    },
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/vscode": "^1.80.0",
        "esbuild": "^0.19.x",
        "typescript": "^5.x"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}