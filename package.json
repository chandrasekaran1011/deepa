{
  "name": "deepa-cli",
  "version": "0.1.1",
  "description": "Universal agentic CLI coding agent — supports OpenAI, Anthropic, local LLMs, MCP, plugins, and skills",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deepa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "build:bin": "npm run build && npx pkg . --targets node18-macos-x64,node18-macos-arm64,node18-linux-x64,node18-linux-arm64,node18-win-x64 --out-path bin"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": "package.json"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "coding",
    "llm",
    "mcp",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "path-to-regexp": "^8.3.0",
    "turndown": "^7.2.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/node": "^22.19.13",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}